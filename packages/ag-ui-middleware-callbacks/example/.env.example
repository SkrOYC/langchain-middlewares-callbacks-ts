# Default live-testing profile for the AG-UI example package.
# Bun loads .env automatically, so copying this to .env is enough.

# Example backend model provider:
# - mock: local deterministic mock model
# - openai-compatible: routes through LangChain ChatOpenAI
EXAMPLE_PROVIDER=openai-compatible

# OpenRouter exposes an OpenAI-compatible API at /api/v1.
# Official docs:
# - https://openrouter.ai/docs
# - https://openrouter.ai/openrouter/free/api
EXAMPLE_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter requires an API key, even for free models.
EXAMPLE_API_KEY=your_openrouter_api_key_here

# Verified free model for the strict Responses API lifecycle:
# reasoning + tools + function_call_output follow-up.
EXAMPLE_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Strictest LangChain message path: Responses API + contentBlocks v1.
EXAMPLE_USE_RESPONSES_API=true
EXAMPLE_OUTPUT_VERSION=v1

# Used by example/custom-host.ts and verify:custom-host
EXAMPLE_AUTH_TOKEN=demo-secret
