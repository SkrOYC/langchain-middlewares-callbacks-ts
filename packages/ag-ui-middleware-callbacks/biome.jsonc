{
	"$schema": "../../node_modules/@biomejs/biome/configuration_schema.json",
	"extends": ["ultracite/biome/core"],
	"javascript": {
		"globals": ["Bun"]
	},
	"overrides": [
		{
			"includes": [
				"src/index.ts",
				"src/callbacks.ts",
				"src/middleware.ts",
				"src/events/index.ts"
			],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off"
					}
				}
			}
		}
	]
}
