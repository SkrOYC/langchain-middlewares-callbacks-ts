# =============================================================================
# Google Gemma Model Configuration
# =============================================================================
GOOGLE_API_KEY=your-google-api-key-here
# Or use a key pool for per-key rotation/cooldown.
# Comma or newline separated.
# GOOGLE_API_KEYS=key-1,key-2,key-3

# Model configuration
EVAL_MODEL=gemma-3-27b-it
EVAL_TEMPERATURE=0
EVAL_MAX_RETRIES=2
EVAL_MAX_TOKENS=16384
RMM_LOG_LEVEL=INFO
# EVAL_LOG_KEY_ROTATION=true

# =============================================================================
# LongMemEval Runner Defaults
# =============================================================================
EVAL_MODE=all
EVAL_PAPER_STRICT=true
EVAL_METHODS=rmm
EVAL_PREBUILD_METHODS=rmm
EVAL_MODEL_ADAPTER=./scripts/adapters/google-gemma-model-adapter.ts
EVAL_REFLECTION_MODEL_ADAPTER=./scripts/adapters/google-gemma-model-adapter.ts
EVAL_JUDGE_ADAPTER=./scripts/adapters/google-gemma-judge-adapter.ts
EVAL_EMBEDDINGS_ADAPTER=./scripts/adapters/huggingface-embeddings-adapter.ts
EVAL_SAVE_ARTIFACTS=true
EVAL_RESUME=true
EVAL_PREBUILD_TOPIC_BANK=true
EVAL_PREBUILD_SPEAKER2=false
EVAL_PREBUILD_ALL_BEFORE_EVALUATION=true
EVAL_REQUIRE_PREBUILD=true
EVAL_ALLOW_RAW_FALLBACK=false
EVAL_STRICT_PREBUILD_COVERAGE=1
EVAL_RETRIEVAL_METRIC_SOURCE=topm
EVAL_REFLECTION_CACHE=true
EVAL_REFLECTION_CACHE_PATH=./data/longmemeval/cache/reflection-cache.jsonl
EVAL_VECTOR_STORE_CACHE=true
EVAL_VECTOR_STORE_CACHE_DIR=./data/longmemeval/cache/vector-stores.s1only.c20
EVAL_EMBEDDING_CACHE=true
EVAL_EMBEDDING_CACHE_PATH=./data/longmemeval/cache/embeddings

# Separate models for per-step configuration (optional)
# If not set, defaults to EVAL_MODEL
# EVAL_EXTRACTION_MODEL=gemma-3-4b-it
# EVAL_UPDATE_MODEL=gemma-3-12b-it

# Judge configuration
EVAL_JUDGE_MODEL=gemma-3-27b-it
EVAL_JUDGE_TEMPERATURE=0
EVAL_JUDGE_MAX_TOKENS=256

# =============================================================================
# Embeddings Configuration (used by run-agent-longmemeval.ts)
# =============================================================================
EVAL_EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
EVAL_EMBEDDING_DIMENSION=384
EVAL_EMBEDDING_DTYPE=float32
# EVAL_EMBEDDING_ENCODING=cl100k_base

# =============================================================================
# Concurrency Settings
# =============================================================================
EVAL_PREBUILD_CONCURRENCY=20
EVAL_CONCURRENCY=20

# =============================================================================
# Retry Settings
# =============================================================================
EVAL_PREBUILD_ZERO_MEMORY_RETRIES=2
