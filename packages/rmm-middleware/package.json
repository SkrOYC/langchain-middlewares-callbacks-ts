{
  "name": "@skroyc/rmm-middleware",
  "version": "0.1.0",
  "description": "Reflective Memory Management (RMM) middleware for LangChain.js with learnable reranking",
  "keywords": [
    "langchain",
    "memory",
    "middleware",
    "reranker",
    "reinforcement-learning",
    "rmm"
  ],
  "author": "SkrOYC <oscar@ocmasesorias.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skrOYC/langchain-middlewares-callbacks-ts.git",
    "directory": "packages/rmm-middleware"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "peerDependencies": {
    "langchain": "catalog:peer",
    "@langchain/core": "catalog:peer",
    "@langchain/langgraph": "catalog:peer",
    "@langchain/langgraph-checkpoint": "catalog:peer",
    "zod": "catalog:peer",
    "typescript": "catalog:peer"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": false
    },
    "@langchain/core": {
      "optional": false
    },
    "@langchain/langgraph": {
      "optional": false
    },
    "@langchain/langgraph-checkpoint": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "download:longmemeval": "bun scripts/download-longmemeval.ts --which all --out-dir ./data/longmemeval",
    "eval:longmemeval:agent": "bun scripts/run-agent-longmemeval.ts",
    "eval:longmemeval:gemma:s": "bun scripts/run-agent-longmemeval.ts --dataset ./data/longmemeval/longmemeval_s_cleaned.json --out-dir ./artifacts/longmemeval-s-gemma",
    "eval:longmemeval:gemma:m": "bun scripts/run-agent-longmemeval.ts --dataset ./data/longmemeval/longmemeval_m_cleaned.json --out-dir ./artifacts/longmemeval-m-gemma",
    "eval:longmemeval:gemma:oracle": "bun scripts/run-agent-longmemeval.ts --dataset ./data/longmemeval/longmemeval_oracle.json --out-dir ./artifacts/longmemeval-oracle-gemma",
    "eval:longmemeval:gemma:s:phase2": "bun scripts/run-agent-longmemeval.ts --mode eval --dataset ./data/longmemeval/longmemeval_s_cleaned.json --out-dir ./artifacts/longmemeval-s-gemma-s1only-c20-eval",
    "lint": "bunx --bun @biomejs/biome check src tests",
    "check": "bunx biome check",
    "fix": "bunx biome check --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langchain/anthropic": "^1.3.19",
    "@langchain/community": "^1.1.17",
    "@langchain/google-genai": "catalog:",
    "@langchain/openai": "^1.2.10"
  }
}
